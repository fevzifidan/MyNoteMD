# AI Service Configuration
# Copy this file to .ai.env and fill in your values

# The model ID to use for text generation
# Examples: 
# - onnx-community/Qwen2.5-1.5B-Instruct
# - HuggingFaceTB/SmolLM2-135M-Instruct
# - onnx-community/Qwen2.5-0.5B-Instruct
VITE_AI_MODEL_ID=onnx-community/Qwen2.5-1.5B-Instruct

# Device (e.g., "auto" | "gpu" | "cpu" | "wasm" | "webgpu" | "cuda" | "dml" | "webnn" | "webnn-npu" | "webnn-gpu" | "webnn-cpu" | Record<string, "auto" | "gpu" | "cpu" | "wasm" | "webgpu" | "cuda" | "dml" | "webnn" | "webnn-npu" | "webnn-gpu" | "webnn-cpu"> | undefined)
VITE_AI_DEVICE=wasm

# quantization type (e.g., q4, q8, fp16) - Note: browser wasm limits might affect this
VITE_AI_DTYPE=q8

# Maximum number of new tokens to generate
VITE_AI_MAX_NEW_TOKENS=25

# Temperature for sampling (0.0 to 1.0)
VITE_AI_TEMPERATURE=0.1

# Repetition penalty
VITE_AI_REPETITION_PENALTY=1.1

# Do sample
VITE_AI_DO_SAMPLE=false

# Top k
VITE_AI_TOP_K=40

# Embedding model ID
# Examples:
# - Xenova/all-MiniLM-L6-v2
# - onnx-community/all-MiniLM-L6-v2-ONNX
VITE_AI_EMBEDDING_MODEL_ID=Xenova/all-MiniLM-L6-v2

# System Prompt
VITE_AI_SYSTEM_PROMPT="You are a precise data extraction assistant. Your task is to find the specific answer to the user's question within the provided text. If the answer is there, provide it directly. If not, say you couldn't find it."
